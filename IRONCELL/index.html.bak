<script>
  // Update price when strength is changed
  function updatePrice(select) {
    const price = select.value;
    const priceEl = select.closest('.product-info').querySelector('.product-price');
    priceEl.textContent = '$' + price;
  }

  // Product Data
  const products = [
    {
      name: "Retatrutide",
      subtitle: "Triple-Agonist Injectable · GIP/GLP-1/Glucagon",
      desc: "Retatrutide is an investigational, once-weekly injectable therapy designed to target obesity and metabolic disorders through a powerful triple-agonist mechanism. By activating GIP, GLP-1, and glucagon receptors simultaneously, it helps reduce appetite, improve metabolic function, and increase energy expenditure. Early clinical trials show substantial weight-loss potential and promising improvements in metabolic health, positioning retatrutide as a next-generation option currently advancing through Phase 3 development.",
      strengths: ["10mg — $129.99", "20mg — $159.99", "30mg — $179.99"],
      price: "$129.99"
    },
    {
      name: "Tirzepatide",
      subtitle: "Dual GIP/GLP-1 Agonist Injectable",
      desc: "Tirzepatide is a once-weekly injectable medication that combines dual GIP and GLP-1 receptor agonism to support powerful improvements in weight management and metabolic health. By enhancing insulin response, reducing appetite, and slowing gastric emptying, it delivers significant reductions in body weight and blood glucose levels. Approved for type 2 diabetes and chronic weight management, tirzepatide represents a next-generation incretin therapy with strong clinical outcomes across metabolic conditions.",
      strengths: ["10mg — $79.99", "20mg — $99.99"],
      price: "$79.99"
    },
    {
      name: "BPC-157 & TB-500",
      subtitle: "Tissue Repair Peptide Blend",
      desc: "BPC-157 and TB-500 blend is a research-grade peptide combination formulated to support tissue repair and recovery. BPC-157, a synthetic fragment of a naturally occurring gastric protein, is studied for its potential role in promoting cellular healing and reducing inflammation, while TB-500, a synthetic version of thymosin beta-4, is investigated for its ability to enhance tissue regeneration and support mobility. Together, this combination is explored in research settings for synergistic effects on soft-tissue recovery and overall repair processes.",
      strengths: ["10mg — $59.99", "20mg — $79.99"],
      price: "$59.99"
    },
    {
      name: "GHK-Cu",
      subtitle: "Copper Peptide · Skin & Tissue Rejuvenation",
      desc: "GHK-Cu is a naturally occurring copper-binding peptide studied for its potential role in supporting skin repair, collagen production, and overall tissue rejuvenation. Known for its ability to influence cellular signaling and promote a healthier extracellular matrix, GHK-Cu is widely explored in research and topical formulations aimed at improving skin firmness, elasticity, and visible signs of aging. Its regenerative profile has made it a prominent peptide of interest in cosmetic and biomedical research settings.",
      strengths: ["50mg — $39.99", "100mg — $59.99"],
      price: "$39.99"
    },
    {
      name: "MOTS-c",
      subtitle: "Mitochondrial Peptide · 10mg",
      desc: "MOTS-c is a mitochondria-derived peptide studied for its potential role in supporting metabolic balance, cellular energy production, and overall physiological resilience. By influencing pathways related to glucose utilization and mitochondrial function, MOTS-c is explored in research settings for its ability to enhance exercise performance, promote metabolic flexibility, and support healthy aging processes. Its unique origin and broad metabolic activity have made it a notable peptide of interest in longevity and performance science.",
      strengths: null,
      price: "$44.99"
    },
    {
      name: "NAD⁺",
      subtitle: "Coenzyme · 1000mg",
      desc: "NAD⁺ (nicotinamide adenine dinucleotide) is a vital coenzyme found in every cell, essential for supporting energy production, metabolic function, and cellular repair. As a central player in mitochondrial activity and DNA maintenance, NAD⁺ levels naturally decline with age, prompting interest in supplementation strategies that may help sustain metabolic efficiency and promote healthy aging. Its foundational role in cellular resilience has made NAD⁺ a key focus in longevity, performance, and wellness research.",
      strengths: null,
      price: "$99.99"
    },
    {
      name: "Glutathione",
      subtitle: "Antioxidant · 1500mg",
      desc: "Glutathione is a powerful intracellular antioxidant essential for supporting cellular detoxification, immune function, and overall oxidative balance. As a key defender against free-radical stress, it plays a central role in maintaining mitochondrial health, recycling other antioxidants, and promoting optimal metabolic function. Because natural levels can decline with age, stress, or environmental exposure, glutathione is widely explored in wellness and research settings for its potential to enhance cellular resilience and support whole-body vitality.",
      strengths: null,
      price: "$54.99"
    },
    {
      name: "Vitamin B12",
      subtitle: "Essential Nutrient · Energy & Nerve Support",
      desc: "Vitamin B12 is an essential water-soluble nutrient that supports energy production, red blood cell formation, and healthy nervous system function. As a key cofactor in metabolic and methylation pathways, B12 helps maintain cognitive clarity, cellular vitality, and overall metabolic balance. Because levels can decline with age, dietary patterns, or absorption challenges, B12 supplementation is widely used to help sustain energy, support neurological health, and promote overall wellness.",
      strengths: null,
      price: "$44.99"
    },
    {
      name: "L-Carnitine",
      subtitle: "Amino Acid · Fat Metabolism & Performance",
      desc: "L-Carnitine is a naturally occurring amino-acid-derived compound essential for transporting fatty acids into the mitochondria, where they can be converted into usable energy. Widely studied for its role in supporting metabolic efficiency, exercise performance, and cellular energy production, L-Carnitine helps promote endurance, recovery, and overall vitality. Because levels can be influenced by diet, age, and activity, supplementation is often explored to help maintain optimal energy metabolism and support active, wellness-focused lifestyles.",
      strengths: null,
      price: "$44.99"
    },
    {
      name: "Bacteriostatic Water",
      subtitle: "Sterile Diluent · Research Supply",
      desc: "Bacteriostatic Water is a sterile, non-pyrogenic preparation of water for injection containing 0.9% benzyl alcohol as a bacteriostatic preservative. It is commonly used in research settings as a diluent for reconstituting lyophilized (freeze-dried) peptides and compounds prior to use. Available in 3ml and 10ml vials.",
      strengths: ["3ml — $5.99", "10ml — $9.99"],
      price: "$5.99"
    }
  ];

  function openModal(index) {
    const p = products[index];
    document.getElementById('modalName').textContent = p.name;
    document.getElementById('modalSubtitle').textContent = p.subtitle;
    document.getElementById('modalDesc').textContent = p.desc;
    document.getElementById('modalPrice').textContent = p.price;
    document.getElementById('productModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    document.getElementById('productModal').classList.remove('active');
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  // ─── CART SYSTEM ───
  let cart = [];

  function generateOrderNumber() {
    return Math.floor(100000 + Math.random() * 900000).toString();
  }

  function getSelectedStrength(card) {
    const select = card.querySelector('.strength-select');
    if (select) {
      return select.options[select.selectedIndex].text;
    }
    return null;
  }

  function getSelectedPrice(card) {
    const select = card.querySelector('.strength-select');
    if (select) {
      return parseFloat(select.value);
    }
    const priceEl = card.querySelector('.product-price');
    return parseFloat(priceEl.textContent.replace('$', ''));
  }

  function getProductName(card) {
    return card.querySelector('.product-name').textContent;
  }

  // Attach add-to-cart handlers
  document.querySelectorAll('.btn-add-cart').forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      const card = this.closest('.product-card');
      const name = getProductName(card);
      const strength = getSelectedStrength(card);
      const price = getSelectedPrice(card);
      const key = name + (strength ? ' — ' + strength : '');

      const existing = cart.find(item => item.key === key);
      if (existing) {
        existing.qty++;
      } else {
        cart.push({ key, name, strength, price, qty: 1 });
      }

      updateCartUI();
      toggleCart(true);

      // Button feedback
      const orig = this.textContent;
      this.textContent = 'Added ✓';
      this.style.background = '#1a7a2e';
      setTimeout(() => {
        this.textContent = orig;
        this.style.background = '';
      }, 1000);
    });
  });

  function updateCartUI() {
    const itemsEl = document.getElementById('cartItems');
    const countEl = document.getElementById('cartCount');
    const totalEl = document.getElementById('cartTotal');
    const subtotalEl = document.getElementById('cartSubtotal');
    const checkoutBtn = document.getElementById('btnCheckout');

    const totalItems = cart.reduce((sum, item) => sum + item.qty, 0);
    const totalPrice = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);

    countEl.textContent = totalItems;
    totalEl.textContent = '$' + totalPrice.toFixed(2);
    subtotalEl.textContent = '$' + totalPrice.toFixed(2);
    checkoutBtn.disabled = cart.length === 0;

    if (cart.length === 0) {
      itemsEl.innerHTML = '<div class="cart-empty">Your cart is empty</div>';
      return;
    }

    itemsEl.innerHTML = cart.map((item, i) => `
      <div class="cart-item">
        <div class="cart-item-icon">
          <svg viewBox="0 0 24 24"><path d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
        </div>
        <div class="cart-item-details">
          <div class="cart-item-name">${item.name}</div>
          ${item.strength ? `<div class="cart-item-strength">${item.strength}</div>` : ''}
          <div class="cart-item-price">$${(item.price * item.qty).toFixed(2)}</div>
        </div>
        <div class="cart-item-qty">
          <button onclick="changeQty(${i}, -1)">−</button>
          <span>${item.qty}</span>
          <button onclick="changeQty(${i}, 1)">+</button>
        </div>
        <button class="cart-item-remove" onclick="removeItem(${i})">&times;</button>
      </div>
    `).join('');
  }

  function changeQty(index, delta) {
    cart[index].qty += delta;
    if (cart[index].qty <= 0) cart.splice(index, 1);
    updateCartUI();
  }

  function removeItem(index) {
    cart.splice(index, 1);
    updateCartUI();
  }

  function toggleCart(forceOpen) {
    const sidebar = document.getElementById('cartSidebar');
    const overlay = document.getElementById('cartOverlay');
    const isOpen = sidebar.classList.contains('open');
    if (forceOpen === true || !isOpen) {
      sidebar.classList.add('open');
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    } else {
      sidebar.classList.remove('open');
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    }
  }

  function openCheckout() {
    if (cart.length === 0) return;
    toggleCart(); // close cart

    const modal = document.getElementById('checkoutModal');
    const summary = document.getElementById('checkoutSummary');
    const orderNum = document.getElementById('orderNumber');

    // Generate order number
    orderNum.textContent = generateOrderNumber();

    // Build summary
    const totalPrice = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
    let html = cart.map(item => `
      <div class="checkout-summary-item">
        <span class="item-name">${item.name}${item.strength ? ' · ' + item.strength : ''} × ${item.qty}</span>
        <span class="item-price">$${(item.price * item.qty).toFixed(2)}</span>
      </div>
    `).join('');
    html += `<div class="checkout-total"><span>Total</span><span>$${totalPrice.toFixed(2)}</span></div>`;
    summary.innerHTML = html;

    modal.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeCheckout() {
    document.getElementById('checkoutModal').classList.remove('active');
    document.body.style.overflow = '';
  }

  function handlePayment(method) {
    const orderNum = document.getElementById('orderNumber').textContent;
    const name = document.getElementById('custName').value || 'Not provided';
    const email = document.getElementById('custEmail').value || 'Not provided';
    const address = document.getElementById('custAddress').value || 'Not provided';
    const totalPrice = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
    
    const itemsList = cart.map(item => 
      `${item.name}${item.strength ? ' (' + item.strength + ')' : ''} x${item.qty} - $${(item.price * item.qty).toFixed(2)}`
    ).join('%0A');

    const subject = encodeURIComponent(`New Order #${orderNum} - IronCell Research`);
    const body = encodeURIComponent(
      `NEW ORDER RECEIVED\n` +
      `═══════════════════\n\n` +
      `Order #: ${orderNum}\n` +
      `Payment Method: ${method.toUpperCase()}\n\n` +
      `CUSTOMER INFO:\n` +
      `Name: ${name}\n` +
      `Email: ${email}\n` +
      `Address: ${address}\n\n` +
      `ITEMS:\n` +
      cart.map(item => 
        `• ${item.name}${item.strength ? ' (' + item.strength + ')' : ''} x${item.qty} — $${(item.price * item.qty).toFixed(2)}`
      ).join('\n') +
      `\n\nTOTAL: $${totalPrice.toFixed(2)}\n\n` +
      `═══════════════════\n` +
      `Sent from IronCell Research website`
    );

    // Open email to store owner with order details
    const mailLink = document.createElement('a');
    mailLink.href = `mailto:IRCELLRESEARCH@protonmail.com?subject=${subject}&body=${body}`;
    mailLink.click();
  }

  function subscribeNewsletter() {
    const emailInput = document.getElementById('newsletterEmail');
    const email = emailInput.value.trim();
    if (!email || !email.includes('@')) {
      emailInput.style.borderColor = 'var(--red-primary)';
      emailInput.placeholder = 'Please enter a valid email';
      return;
    }
    const subject = encodeURIComponent('New Newsletter Subscriber - IronCell Research');
    const body = encodeURIComponent(`New newsletter subscriber:\n\nEmail: ${email}\n\nSent from IronCell Research website`);
    const mailLink = document.createElement('a');
    mailLink.href = `mailto:IRCELLRESEARCH@protonmail.com?subject=${subject}&body=${body}`;
    mailLink.click();
    emailInput.value = '';
    emailInput.placeholder = 'Subscribed! Thank you.';
    emailInput.style.borderColor = '#1a7a2e';
    setTimeout(() => {
      emailInput.placeholder = 'Enter your email address';
      emailInput.style.borderColor = '';
    }, 3000);
  }

  // Age Gate
  function closeAgeGate() {
    document.getElementById('ageGate').classList.add('hidden');
  }

  // Mobile Menu
  function toggleMobile() {
    document.getElementById('mobileMenu').classList.toggle('active');
  }

  // Scroll Reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // ─── SPARK RING ANIMATION ───
  (function() {
    const canvas = document.getElementById('sparkCanvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let w, h, cx, cy, particles = [], ringParticles = [], time = 0;

    function resize() {
      const hero = canvas.parentElement;
      w = canvas.width = hero.offsetWidth;
      h = canvas.height = hero.offsetHeight;
      // Find the logo and center the ring on it
      const logo = document.querySelector('.hero-logo-img');
      if (logo) {
        const heroRect = hero.getBoundingClientRect();
        const logoRect = logo.getBoundingClientRect();
        cx = (logoRect.left - heroRect.left) + logoRect.width / 2;
        cy = (logoRect.top - heroRect.top) + logoRect.height / 2;
      } else {
        cx = w / 2;
        cy = h / 2;
      }
    }
    resize();
    window.addEventListener('resize', resize);

    // Get ring size based on logo
    function getRingRadius() {
      const logo = document.querySelector('.hero-logo-img');
      if (logo) {
        return Math.max(logo.offsetWidth, logo.offsetHeight) * 0.55;
      }
      return 260;
    }
    function getRingYRatio() {
      const logo = document.querySelector('.hero-logo-img');
      if (logo) {
        return (logo.offsetHeight / logo.offsetWidth) * 1.1;
      }
      return 0.55;
    }

    // Ember particle
    class Ember {
      constructor() { this.reset(); }
      reset() {
        const angle = Math.random() * Math.PI * 2;
        const radius = getRingRadius() + Math.random() * 40;
        const yRatio = getRingYRatio();
        this.x = cx + Math.cos(angle) * radius;
        this.y = cy + Math.sin(angle) * (radius * yRatio);
        this.vx = (Math.random() - 0.5) * 3;
        this.vy = -Math.random() * 3 - 0.8;
        this.life = 1;
        this.decay = 0.006 + Math.random() * 0.012;
        this.size = Math.random() * 3.5 + 1;
        this.hue = 15 + Math.random() * 25; // orange-red range
      }
      update() {
        this.x += this.vx;
        this.y += this.vy;
        this.vy -= 0.01; // float up
        this.vx *= 0.99;
        this.life -= this.decay;
        if (this.life <= 0) this.reset();
      }
      draw() {
        const alpha = this.life * 0.8;
        const glow = this.size * 3;
        // Glow
        const grad = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, glow);
        grad.addColorStop(0, `hsla(${this.hue}, 100%, 70%, ${alpha})`);
        grad.addColorStop(0.4, `hsla(${this.hue}, 100%, 50%, ${alpha * 0.4})`);
        grad.addColorStop(1, `hsla(${this.hue}, 100%, 30%, 0)`);
        ctx.beginPath();
        ctx.arc(this.x, this.y, glow, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
        // Core
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size * this.life, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(${this.hue + 20}, 100%, 85%, ${alpha})`;
        ctx.fill();
      }
    }

    // Ring particle (forms the fire ring)
    class RingParticle {
      constructor(offset) {
        this.offset = offset;
        this.wobble = Math.random() * 20;
        this.speed = 0.006 + Math.random() * 0.002;
        this.size = 3 + Math.random() * 5;
        this.hue = 10 + Math.random() * 30;
        this.brightness = 50 + Math.random() * 30;
      }
      update() {
        this.angle = this.offset + time * this.speed;
        const baseR = getRingRadius();
        const yRatio = getRingYRatio();
        const wobbleAmt = Math.sin(time * 0.03 + this.offset * 3) * this.wobble;
        const r = baseR + wobbleAmt;
        this.x = cx + Math.cos(this.angle) * r;
        this.y = cy + Math.sin(this.angle) * (r * yRatio);
      }
      draw() {
        const flicker = 0.6 + Math.sin(time * 0.1 + this.offset * 5) * 0.4;
        const glowSize = this.size * 4 * flicker;
        // Outer glow
        const grad = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, glowSize);
        grad.addColorStop(0, `hsla(${this.hue}, 100%, ${this.brightness + 20}%, ${0.7 * flicker})`);
        grad.addColorStop(0.3, `hsla(${this.hue}, 100%, ${this.brightness}%, ${0.3 * flicker})`);
        grad.addColorStop(1, `hsla(${this.hue}, 100%, 20%, 0)`);
        ctx.beginPath();
        ctx.arc(this.x, this.y, glowSize, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
        // Hot core
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size * 0.6 * flicker, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(${this.hue + 30}, 100%, 90%, ${0.9 * flicker})`;
        ctx.fill();
      }
    }

    // Initialize particles
    for (let i = 0; i < 80; i++) particles.push(new Ember());
    for (let i = 0; i < 160; i++) ringParticles.push(new RingParticle((i / 160) * Math.PI * 2));

    // Traveling spark (the bright spark that circles)
    let sparkAngle = 0;
    const sparkSpeed = 0.02;

    function drawTravelingSpark() {
      sparkAngle += sparkSpeed;
      const r = getRingRadius();
      const yRatio = getRingYRatio();
      const sx = cx + Math.cos(sparkAngle) * r;
      const sy = cy + Math.sin(sparkAngle) * (r * yRatio);
      
      // Bright core
      const grad = ctx.createRadialGradient(sx, sy, 0, sx, sy, 40);
      grad.addColorStop(0, 'hsla(40, 100%, 95%, 1)');
      grad.addColorStop(0.1, 'hsla(30, 100%, 80%, 0.9)');
      grad.addColorStop(0.3, 'hsla(20, 100%, 60%, 0.5)');
      grad.addColorStop(1, 'hsla(10, 100%, 30%, 0)');
      ctx.beginPath();
      ctx.arc(sx, sy, 40, 0, Math.PI * 2);
      ctx.fillStyle = grad;
      ctx.fill();

      // Spawn trail embers
      if (Math.random() < 0.8) {
        const e = new Ember();
        e.x = sx + (Math.random() - 0.5) * 14;
        e.y = sy + (Math.random() - 0.5) * 14;
        e.vx = (Math.random() - 0.5) * 4;
        e.vy = -Math.random() * 3.5 - 1;
        e.life = 0.6 + Math.random() * 0.4;
        e.size = 1.5 + Math.random() * 2.5;
        particles.push(e);
        // Keep particle count in check
        if (particles.length > 200) particles.splice(0, 1);
      }
    }

    function animate() {
      ctx.clearRect(0, 0, w, h);
      time++;

      // Draw ring glow (subtle)
      const glowR = getRingRadius();
      const glowYR = getRingYRatio();
      ctx.beginPath();
      ctx.ellipse(cx, cy, glowR, glowR * glowYR, 0, 0, Math.PI * 2);
      ctx.strokeStyle = `hsla(15, 100%, 40%, ${0.08 + Math.sin(time * 0.02) * 0.03})`;
      ctx.lineWidth = 16;
      ctx.stroke();

      // Ring particles
      ringParticles.forEach(p => {
        p.update();
        p.draw();
      });

      // Embers
      particles.forEach(p => {
        p.update();
        p.draw();
      });
      particles = particles.filter(p => p.life > 0);

      // Traveling spark
      drawTravelingSpark();

      requestAnimationFrame(animate);
    }

    animate();
  })();
  </script>
</body>
</html>